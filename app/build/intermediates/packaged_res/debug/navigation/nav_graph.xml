<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/chatFragment">

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.vonnegut.app.ui.chat.ChatFragment"
        android:label="Vonnegut">

        <action
            android:id="@+id/action_chat_to_sessions"
            app:destination="@id/sessionsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_chat_to_settings"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/sessionsFragment"
        android:name="com.vonnegut.app.ui.sessions.SessionsFragment"
        android:label="Sessions">

        <action
            android:id="@+id/action_sessions_to_chat"
            app:destination="@id/chatFragment"
            app:popUpTo="@id/chatFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.vonnegut.app.ui.settings.SettingsFragment"
        android:label="Settings">

        <action
            android:id="@+id/action_settings_to_model_manager"
            app:destination="@id/modelManagerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/modelManagerFragment"
        android:name="com.vonnegut.app.ui.model.ModelManagerFragment"
        android:label="Models" />

</navigation>
